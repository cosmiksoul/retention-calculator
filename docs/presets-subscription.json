{
  "$schema_version": "1.0",
  "$last_updated": "2026-05-05",
  "$mode": "subscription",
  "$notes": "These verticals operate on subscription metrics, NOT daily session retention. Retention is measured against PAYING SUBSCRIBERS (not installs). To compute LTV per install, multiply: install_to_trial × trial_to_paid × ARPU × avg_subscription_months. Tier definitions: T1=US/UK/CA/AU/DACH/Nordics; T2=W/S Europe + JP/KR; T3=LATAM/SEA/India/EE/CIS.",
  "$sources_note": "Sources for all numbers are documented in temp/methodology-subs.md (will be moved to docs/methodology-subscription.md when v2 lands).",
  "$weekly_data_note": "Weekly retention is provided ONLY for verticals where weekly billing dominates (utilities, photo_video) AND only at top_quartile|tier_1 + median|tier_1 (other variants lack public data). For other verticals, weekly_data_status='not_applicable'. See temp/weekly-research-findings.md for full methodology and confidence levels.",
  "$metric_definitions": {
    "install_to_trial": "% of installs that start a free trial (RevenueCat: 7-day window)",
    "trial_to_paid": "% of trials that convert to paid subscription",
    "M1_retention": "% of paid subscribers still active at month 1",
    "M3_retention": "% of paid subscribers still active at month 3",
    "M6_retention": "% of paid subscribers still active at month 6",
    "M12_retention": "% of paid subscribers still active at month 12 (annual plan renewal)",
    "rpi_d14": "Revenue per install at day 14 USD (RevenueCat standard)",
    "rpi_d60": "Revenue per install at day 60 USD",
    "arpu_paid_monthly": "Average revenue per PAYING user per month USD",
    "cpi_blended": "Cost per install blended across iOS/Android USD",
    "cpi_ios": "iOS CPI USD",
    "cpi_android": "Android CPI USD"
  },
